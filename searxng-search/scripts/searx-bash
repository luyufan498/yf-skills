#!/usr/bin/env bash
# SearXNG search helper script with smart engine selection and retry logic

set -o pipefail

# Default values
QUERY=""
SERVER="${SEARXNG_URL:-}"
CATEGORY="general"
LIMIT=10
ENGINES=""
RAW_JSON=false
TIME_RANGE=""
MAX_RETRIES=2

# Define preferred engines for random selection (multiple engines for better results)
# Using multiple engines reduces chance of complete failure
PREFERRED_ENGINES=("yandex,sogou" "yandex,baidu" "yandex,360search" "yandex,brave" "yandex,yahoo" "sogou,baidu" "sogou,360search" "sogou,brave" "sogou,yahoo" "baidu,360search" "baidu,brave" "baidu,yahoo" "360search,brave" "360search,yahoo" "brave,yahoo")

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --server|-s)
      SERVER="$2"
      shift 2
      ;;
    --category|-c)
      CATEGORY="$2"
      shift 2
      ;;
    --limit|-l)
      LIMIT="$2"
      shift 2
      ;;
    --engines|-e)
      ENGINES="$2"
      shift 2
      ;;
    --retries|-r)
      MAX_RETRIES="$2"
      shift 2
      ;;
    --json)
      RAW_JSON=true
      shift
      ;;
    --time-range|-t)
      TIME_RANGE="$2"
      shift 2
      ;;
    --help|-h)
      cat << 'EOF'
Usage: searx-bash <query> [OPTIONS]

Smart SearXNG search with automatic engine selection and retry logic

Options:
  --server, -s       SearXNG server URL (required)
  --category, -c     Search category (default: general)
  --limit, -l        Max results (default: 10)
  --engines, -e      Specific engine(s) to use (overrides auto-selection)
  --time-range, -t   Time filter: day/week/month/year
  --retries, -r      Max retries with different engines (default: 2)
  --json             Output raw JSON
  --help, -h         Show this help

Environment:
  SEARXNG_URL        SearXNG server URL (required)

Features:
  - Auto-selects from 360search, baidu, yandex, sogou, brave, yahoo
  - Retries with different engines on CAPTCHA/Suspended errors
  - Clear error messages for AI agent debugging

Examples:
  searx-bash "python tutorial" --limit 5
  searx-bash "中科曙光" --category general
  searx-bash "tokio" --engines bing --limit 10
EOF
      exit 0
      ;;
    *)
      QUERY="$QUERY $1"
      shift
      ;;
  esac
done

QUERY=$(echo "$QUERY" | xargs)

if [[ -z "$QUERY" ]]; then
  echo "Error: Query is required."
  exit 1
fi

if [[ -z "$SERVER" ]]; then
  echo "Error: SearXNG server URL not set. Use SEARXNG_URL environment variable or --server flag."
  exit 1
fi

if ! command -v jq &> /dev/null; then
  echo "Error: jq is required. Install with: apt install jq or brew install jq"
  exit 1
fi

SERVER="${SERVER%/}"
ENCODED_QUERY=$(printf '%s' "$QUERY" | jq -sRr '@uri')

# Build URL function
build_url() {
  local eng="$1"
  local url="${SERVER}/search?q=${ENCODED_QUERY}&format=json"

  if [[ -n "$eng" ]]; then
    # Use 'engines' parameter (plural) for better results
    url="${url}&engines=${eng}"
  fi

  if [[ "$CATEGORY" != "general" ]]; then
    url="${url}&categories=${CATEGORY}"
  fi

  if [[ -n "$TIME_RANGE" ]]; then
    url="${url}&time_range=${TIME_RANGE}"
  fi

  echo "$url"
}

# Check if engines are blocked
check_blockages() {
  local resp="$1"
  local blocked=$(echo "$resp" | jq -r '.unresponsive_engines // []' | jq -r '.[]?.[1] // ""' | grep -iE "Suspended|CAPTCHA|access denied")
  [[ -n "$blocked" ]]
}

# Get blocked engines
get_blocked_engines() {
  local resp="$1"
  echo "$resp" | jq -r '.unresponsive_engines[]?.[0] // ""' 2>/dev/null
}

# Main search function with retry
search_with_retry() {
  local failed_engines=()
  local attempt=0
  local last_response=""

  while (( attempt <= MAX_RETRIES )); do
    local engine_to_use=""

    if [[ -n "$ENGINES" ]]; then
      engine_to_use="$ENGINES"
    else
      # Get available engines
      local available=()
      for engine in "${PREFERRED_ENGINES[@]}"; do
        if [[ ! " ${failed_engines[*]} " =~ " ${engine} " ]]; then
          available+=("$engine")
        fi
      done

      if (( ${#available[@]} == 0 )); then
        engine_to_use="${PREFERRED_ENGINES[0]}"
      else
        local idx=$((RANDOM % ${#available[@]}))
        engine_to_use="${available[idx]}"
      fi
    fi

    local url=$(build_url "$engine_to_use")

    # Random delay
    sleep $((1 + RANDOM % 2))

    local response=$(curl -s "$url")
    last_response="$response"

    # Check for results
    local result_count=$(echo "$response" | jq -r '.results | length' 2>/dev/null || echo "0")

    if (( result_count > 0 )); then
      echo "$response"
      return 0
    fi

    # Check for blockages
    if check_blockages "$response"; then
      local blocked=$(get_blocked_engines "$response")
      for blocked_eng in $blocked; do
        if [[ ! " ${failed_engines[*]} " =~ " ${blocked_eng} " ]]; then
          failed_engines+=("$blocked_eng")
        fi
      done

      if [[ -n "$ENGINES" ]]; then
        # User specified engines, return what we got
        echo "$response"
        return 1
      fi

      # Try another engine
      ((attempt++))
      continue
    fi

    # No results, no blockages - try another engine if not user specified
    if [[ -z "$ENGINES" ]]; then
      failed_engines+=("$engine_to_use")
      ((attempt++))
      continue
    fi

    # Return the response
    echo "$response"
    return 1
  done

  # All retries failed
  echo "$last_response"
  return 1
}

# Perform search
RESPONSE=$(search_with_retry)
search_status=$?

if [[ $search_status -ne 0 || -z "$RESPONSE" ]]; then
  echo "Error: Search failed after $MAX_RETRIES retries."
  echo ""
  echo "Query: $QUERY"

  if [[ -n "$ENGINES" ]]; then
    echo "Engines: $ENGINES"
  else
    local attempted="${failed_engines[*]:-}"
    echo "Engines attempted: ${attempted:-auto-selected engines from preferred list}"
  fi

  if check_blockages "$RESPONSE"; then
    echo ""
    echo "Blocked engines:"
    echo "$RESPONSE" | jq -r '.unresponsive_engines[] | "  - \(.[0]): \(.[1])"'
  fi

  echo ""
  echo "Solutions:"
  echo "  1. Try: searx-bash --engines 360search \"your query\""
  echo "  2. Simplify search terms"
  echo "  3. Wait and retry (rate limiting)"
  exit 1
fi

# Output
if [[ "$RAW_JSON" == "true" ]]; then
  echo "$RESPONSE"
  exit 0
fi

RESULT_COUNT=$(echo "$RESPONSE" | jq -r '.results | length')

if [[ $RESULT_COUNT -eq 0 ]]; then
  echo "No results found for: $QUERY"
  exit 0
fi

# Display results
echo "Results for: $QUERY"
echo ""

jq -r --arg limit "$LIMIT" '
  .results[0:($limit | tonumber)] | .[] |
  (.title) + "\n" +
  "  URL: " + .url + "\n" +
  "  Engines: " + (.engines | join(", ")) +
  (if .content != null and (.content | length) > 0 then "\n  " + (.content | .[0:200]) + (if (.content | length) > 200 then "..." else "" end) else "" end) +
  "\n"
' <<< "$RESPONSE"

SHOWN_COUNT=$(jq -r --arg limit "$LIMIT" '[.results[0:($limit | tonumber)] | .[]] | length' <<< "$RESPONSE")
echo ""
echo "Showing $SHOWN_COUNT of $RESULT_COUNT results"
